@model Ecommerce.BLL.ProductCategoryVM

@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}

@* drop down for categories
drop down for products
selected product details *@

<div class="d-flex justify-content-center">
    <h2 class="">Product Category</h2>
</div>

<div class="m-2">
    <label asp-for="CatId">Category</label>
    <select asp-for="CatId" asp-items="Model.Categories" id="category-dropdown" class="form-select m-2" required>
        <option value=""> Select Category </option>

    </select>
    <span asp-validation-for="CatId" class="text-danger"></span>
</div>

@*
<label asp-for="ProdId">Product</label>
<select asp-for="ProdId" asp-items="Model.Products" id="product-dropdown" class="form-select" required>
    <option value="">-- Select Product --</option>

</select> 

 *@
<div class="m-2">
    <div id="Products">
    </div>
    </div>
        <div class="m-2">
            <div id="product-details">
            </div>
</div>
@section Scripts {
                    <script>
                                        $(document).ready(function(){
                                                    $('#category-dropdown').change(function(){

                                                                var catId = $(this).val();
                                                                console.log(catId);

                                                                if(catId){
                                                                    $.ajax({
                                                                        url:"/CategoryProducts/GetProductsByCategory/",
                                                                        data: {categoryId : catId },

                                                                        type:'GET',
                                                                        success:function(result){

                                                                                    //show products in the dropdown
                                                                                    console.log(result);
                                                                            $('#Products').html(result);
                                                                            //if a product selected
                                                                            $('#product-dropdown').change(function(){
                                                                                var prodId = $(this).val();
                                                                                if(prodId && catId){
                                                                                     $.ajax({
                                                                                 url:"/CategoryProducts/GetProductById/"+prodId,
                                                                        //data: {productId : prodId },

                                                                        type:'GET',
                                                                        success:function(result){
                                                                              $('#product-details').html(result);

                                                                            },
                                                                         error: function (xhr, status, error) {
                                                                                           console.error("Error fetching employees:", error);
                                                                               }
                                                                               })
                                                                               }else{
                                                                              $('#product-details').empty();

                                                                               }
                                                                        })
                                                                        },
                                                                        error: function (xhr, status, error) {
                                                                                    console.error("Error fetching employees:", error);
                                                                        }
                                                                 })
                                                                 }
                                                                 else{
                                                                    $('#Products').html('');
                                                                }
                                                
                                                                })

                      

                                                    });
        
                    </script>
                }





