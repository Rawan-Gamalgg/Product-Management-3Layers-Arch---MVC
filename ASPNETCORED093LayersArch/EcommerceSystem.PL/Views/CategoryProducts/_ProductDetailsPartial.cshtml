
@{
    // Model is ProductReadVM (single product)
}
@model ProductReadVM



<div class="d-flex justify-content-center align-items-center min-vh-50" style="background: linear-gradient(145deg, #f8f9fc 0%, #e9ecef 100%); padding: 2rem; border-radius: 2rem; margin: 10px 1rem;">
    
    <div class="card text-center shadow-xl border-0 overflow-hidden" style="width: 24rem; border-radius: 1.5rem; transition: transform 0.3s ease, box-shadow 0.3s ease;">
        
        <!-- Decorative top bar -->
        <div @* style="height: 8px; background: linear-gradient(90deg, #f093fb 0%, #f5576c 100%);" *@></div>
        
        <!-- Card header with product name -->
        <div class="card-header bg-white border-0 pt-4 pb-0">
            @*    <div class="d-inline-block p-3 rounded-circle bg-light mb-2" style="box-shadow: 0 4px 10px rgba(0,0,0,0.05);">
                 <i class="bi bi-box-seam" style="font-size: 2rem; color: #6c5ce7;"></i> 
            </div> *@
            <h5 class="card-title fw-bold text-dark mt-2" style="font-size: 1.8rem;">@Model.ProductName</h5>
            @if (@Model.ImageURL != null)
            {
                <div class="card card-img">
                <img src="~/Images/Products/@Model.ImageURL" alt="Alternate Text"  />

            </div>
            }
        </div>
        
        <!-- Card body with details -->
        <div class="card-body px-4 py-3">
            <div class="mb-3 pb-2 border-bottom">
                <h6 class="fw-semibold fs-5">Id: @Model.ProductId</h6>
            </div>
            <div class="mb-3 pb-2 border-bottom">
                @*                 <h6 class="card-subtitle text-muted mb-1"> </h6>
 *@                <p class="fw-semibold fs-5">
                Quantity: @Model.Count
                @if (Model.Count <= 3 && Model.Count > 0)
                {
                    <span class="badge bg-warning text-dark ms-2">Low stock</span>
                }
                else if (Model.Count == 0)
                {
                    <span class="badge bg-danger ms-2">Out of stock</span>
                }
                else
                {
                    <span class="badge bg-success ms-2">In stock</span>
                }
            </p>
        </div>
        <div class="mb-3 pb-2 border-bottom">
            @*                 <h6 class="card-subtitle text-muted mb-1">Price</h6>
 *@                <p class="fw-bold fs-4 text-primary">Price: $@Model.Price.ToString("0.00")</p>
        </div>
        <div class="mb-3">
            @*                 <h6 class="card-subtitle text-muted mb-1">Description</h6>
 *@                <p class="card-text text-secondary mt-2" style="font-style: italic;">@(string.IsNullOrEmpty(Model.ProductDescription) ? "." : Model.ProductDescription)</p>
        </div>
    </div>
        
    <!-- Card footer with action buttons -->
    <div class="card-footer  border-0 pb-4 pt-2">
        <div class="d-flex justify-content-center gap-3">
            <a href="~/Product/update/@Model.ProductId" class="btn btn-outline-success px-4 py-2 rounded-pill fw-semibold">
                <i class="bi bi-pencil-square"></i> Edit
            </a>
                
            <button type="button" class="btn btn-outline-danger px-4 py-2 rounded-pill fw-semibold" data-bs-toggle="modal" data-bs-target="#exampleModal">
                <i class="bi bi-trash3"></i> Delete
            </button>
        </div>
    </div>
</div>
</div>

<!-- Modal  -->
<div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg border-0 rounded-4 overflow-hidden">
            <div class="modal-header bg-danger border-0">
                <h5 class="modal-title text-white fw-bold" id="exampleModalLabel">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>Confirm Deletion
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center py-4">
                <i class="bi bi-trash3" style="font-size: 3rem; color: #dc3545;"></i>
                <p class="mt-3 fs-5">Are you sure you want to delete <strong>@Model.ProductName</strong>?</p>
                @* <p class="text-muted small">This action cannot be undone.</p> *@
            </div>
            <div class="modal-footer border-0 justify-content-center gap-3 pb-4">
                <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                <a href="~/Product/delete/@Model.ProductId" class="btn btn-danger rounded-pill px-4"> Delete</a>
            </div>
        </div>
    </div>
</div>

<!-- Add Bootstrap Icons CDN -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<style>
    /* Custom style for card hover effect */
    .shadow-xl {
        box-shadow: 0 20px 35px -12px rgba(0,0,0,0.2);
    }

    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 30px 45px -15px rgba(0,0,0,0.3);
    }

    .min-vh-50 {
        min-height: 50vh;
    }
    /* Smooth transition for all interactive elements */
    .btn, .card {
        transition: all 0.2s ease-in-out;
    }

    .btn-outline-success:hover i,
    .btn-outline-danger:hover i {
        filter: brightness(0) invert(1);
    }
    /* Subtle background pattern */
    body {
    }

    .d-flex.justify-content-center {
        background: radial-gradient(circle at 10% 20%, rgba(120,119,198,0.05) 0%, rgba(255,255,255,0) 90%);
    }
</style>