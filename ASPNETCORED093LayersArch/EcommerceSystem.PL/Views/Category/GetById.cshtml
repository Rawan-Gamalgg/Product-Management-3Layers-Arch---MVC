
@{
    // Model is CategoryReadVM (contains category details + list of products)
}
@model CategoryReadVM

<a href="~/Category" class="btn btn-outline-secondary mb-4">
    Back to List
</a>

<h1 class="text-uppercase text-center mb-5" style="background: linear-gradient(135deg, white 0%, black 100%); background-clip: text; -webkit-background-clip: text; color: transparent; font-weight: 800; letter-spacing: 2px;">
    @Model.Name Category Details
</h1>

<div class="container px-4" style="background: radial-gradient(circle at 10% 20%, rgba(120,119,198,0.05) 0%, rgba(255,255,255,0) 90%); border-radius: 2rem; padding: 2rem 1rem;">
    @if (Model.Products.Count == 0)
    {
        <div class="alert bg-secondary text-white text-center py-5 rounded-4">
            No Products yet
        </div>
    }
    else
    {
        <div class="row g-4 justify-content-center">
            @foreach (var product in Model.Products)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 text-center border-0 overflow-hidden shadow-lg"
                         style="border-radius: 1.5rem; transition: transform 0.3s ease, box-shadow 0.3s ease; background: #ffffff;">
                        
                        <!-- Card header: product name -->
                        <div class="card-header bg-white border-0 pt-4 pb-0">
                            <h5 class="card-title fw-bold text-dark mt-2" style="font-size: 1.8rem;">@product.ProductName</h5>
                        </div>
                        
                        <!-- Card body: product ID and price -->
                        <div class="card-body px-4 py-3">
                            <div class="mb-3 pb-2 border-bottom">
                                <h6 class="fw-semibold fs-5">Id: @product.ProductId</h6>   <!-- Fixed: now shows product Id -->
                            </div>
                            <div class="mb-3 pb-2 border-bottom">
                                <p class="fw-bold fs-4 text-primary mb-0">Price: $@product.Price.ToString("0.00")</p>
                            </div>
                        </div>
                        
                        <!-- Card footer: description -->
                        <div class="card-footer bg-white border-0 pb-4 pt-0">
                            <p class="card-text text-secondary mt-2" style="font-style: italic;">
                                @(string.IsNullOrEmpty(product.ProductDescription) ? "." : product.ProductDescription)
                            </p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Add Bootstrap Icons CDN (already present, kept for modal if uncommented) -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    /* Enhanced card styling – no color changes, no icons */
    .shadow-lg {
        box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1), 0 8px 10px -6px rgba(0,0,0,0.02) !important;
    }

    .card {
        transition: transform 0.25s ease-out, box-shadow 0.3s ease;
    }

        .card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 30px -12px rgba(0,0,0,0.2) !important;
        }
    /* Consistent card inner spacing */
    .card-header, .card-body, .card-footer {
        background-color: white;
    }

    .border-bottom {
        border-bottom: 1px solid rgba(0,0,0,0.08) !important;
    }
    /* Slight rounding for the alert */
    .alert.bg-secondary {
        border-radius: 1.5rem;
        background-color: #6c757d !important;
        color: white;
    }
    /* Subtle hover on the back button */
    .btn-outline-secondary:hover {
        transform: translateX(-3px);
        transition: transform 0.2s;
    }
    /* Responsive text on small screens */
    @@media (max-width: 576px) {
        .card-title {
            font-size: 1.4rem !important;
        }

        .fs-4 {
            font-size: 1.25rem !important;
        }
    }
    /* Ensured no icons or emojis are added */
</style>