@{
}
 @model List<CategoryReadVM>
 
<a class="btn btn-success" href="~/Category/create">Create New Category</a>
@* <h1 class="text-uppercase text-muted text-center">cats List</h1>
 *@<h1 class="text-uppercase text-center mb-5" style="background:  linear-gradient(135deg, white 0%, black 100%);background-clip: text; -webkit-background-clip: text; color: transparent; font-weight: 800; letter-spacing: 2px;">
Category List
</h1>
<div class="d-flex justify-content-center align-items-center" style="">


    <hr />
    <table class="table table-hover text-center">
        <thead>
            <tr>
                <th scope="col">Id</th>
                <th scope="col">Title</th>
                <th scope="col">Products Count</th>
               
                <th scope="col">Actions</th>

            </tr>
        </thead>
        <tbody>
           
            @foreach (var cat in Model)
            {
                <tr>
                    <th scope="row">@cat.Id</th>
                    <td>@cat.Name</td>
                    <td>@cat.ProductsCount</td>

                  
                    <td>
                       @*  <a href="~/cat/GetById/@cat.Id" class="btn btn-primary m-2">
                            View Details
                        </a>
                        <a href="~/cat/update/@cat.Id" class="btn btn-outline-warning m-2">
                            Edit
                        </a>
                        *@
                        @Html.ActionLink("Details", "GetById", "Category", new{Id = cat.Id}, new {@class="btn btn-outline-primary m-2"})
                        @Html.ActionLink("Edit", "update", "Category", new{Id = cat.Id}, new {@class="btn btn-outline-warning m-2"})
                        <a href="~/Category/delete/@cat.Id" id="@cat.Id" data-bs-toggle="modal" data-bs-target="#exampleModal+@cat.Id" class="btn btn-outline-danger m-2">
                            Delete
                        </a>


                    
 
                        <!-- Modal  -->
                        <div class="modal fade" id="exampleModal+@cat.Id" tabindex="-1" aria-labelledby="exampleModal+@cat.Id" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content shadow-lg border-0 rounded-4 overflow-hidden">
                                    <div class="modal-header bg-danger border-0">
                                        <h5 class="modal-title text-white fw-bold" id="exampleModal+@cat.Id">
                                            <i class="bi bi-exclamation-triangle-fill me-2"></i>Confirm Deletion
                                        </h5>
                                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body text-center py-4">
                                        <i class="bi bi-trash3" style="font-size: 3rem; color: #dc3545;"></i>
                                        <p class="mt-3 fs-5">Are you sure you want to delete <strong>@cat.Name</strong>?</p>
                                    </div>
                                    <div class="modal-footer border-0 justify-content-center gap-3 pb-4">
                                        <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                                        <a href="~/Category/delete/@cat.Id" class="btn btn-danger rounded-pill px-4"> Delete</a>
                                    </div>
                                </div>
                            </div>
                        </div>

                      
                    </tr>

              
                }


            </tbody>
        </table>
    </div>
    <!-- Add Bootstrap Icons CDN -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
                          